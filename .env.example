# =============================================================================
# AI Research Assistant — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to git.
# =============================================================================

# --- Application ---
APP_NAME=AI Research Assistant
DEBUG=true
LLM_PROVIDER=litellm  # Options: echo (L1), bedrock (L2), litellm (L3+)

# --- AWS Bedrock (Level 2+) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
BEDROCK_MODEL_ID=amazon.titan-text-express-v1

# --- Additional LLM Providers (Level 3+) ---
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# --- LiteLLM (Level 3+) ---
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-litellm-dev-master-key

# --- Database ---
APP_DATABASE_URL=sqlite+aiosqlite:///./research_assistant.db

# --- Temporal (Level 5) ---
TEMPORAL_HOST=localhost:7233
TEMPORAL_TASK_QUEUE=research-queue

# --- MLflow (Level 6) ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=research-assistant-optimization

# --- Agent Search ---
TAVILY_API_KEY=your-tavily-api-key

# --- Agent Memory (Level 4) ---
AGENT_MEMORY_PATH=./agent_memory.json
